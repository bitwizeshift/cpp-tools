 // DecisionConfig represents the configuration for decisions for various hooks.
 type DecisionConfig struct {
+	// FileAccess represents decisions for file access checks, where the key is a
+	// file-path that may include globs, and the value is the configurable
+	// decision for that file path.
+	FileAccess map[string]FileAccessDecision `yaml:"file-access"`
+
 	// PreToolUse represents decisions to be automatically made for pre-tool-use
 	// hooks.
 	PreToolUse PreToolUseDecision `yaml:"pre-tool-use"`
 }

+// FilePermission represents the type of file access permission to check for in
+// a FileAccessDecision.
+type FilePermission string
+
+const (
+	// FilePermissionRead represents the Read file permission, which allows a tool to read a file's contents.
+	FilePermissionRead FilePermission = "read"
+
+	// FilePermissionWrite represents the Write file permission, which allows a
+	// tool to modify a file's contents.
+	FilePermissionWrite FilePermission = "write"
+
+	// FilePermissionReadWrite represents both Read and Write file permissions.
+	FilePermissionReadWrite FilePermission = "readwrite"
+)
+
+// UnmarshalText implements the encoding.TextUnmarshaler interface for
+// FilePermission, ensuring that only valid file permissions can be unmarshaled
+// from YAML.
+func (fp *FilePermission) UnmarshalText(text []byte) error {
+	switch string(text) {
+	case string(FilePermissionRead), string(FilePermissionWrite), string(FilePermissionReadWrite):
+		*fp = FilePermission(text)
+		return nil
+	default:
+		return fmt.Errorf("invalid file permission: %s", text)
+	}
+}
+
+var _ encoding.TextUnmarshaler = (*FilePermission)(nil)
+
+// FileAccessDecision represents a file path that should be checked before
+// allowing a tool to be used. If the file path matches, the specified decision
+// is returned.
+type FileAccessDecision struct {
+	// Permission is the file permission that should be checked before allowing a
+	// tool to be used.
+	Permission FilePermission `yaml:"permission"`
+
+	// Decision is the decision to make if the file path matches.
+	Decision claude.Decision `yaml:"decision"`
+
+	// Reason is an optional reason for the decision, which can be used to provide
+	// additional context to the user or claude for why the decision was made.
+	Reason string `yaml:"reason,omitempty"`
+}
